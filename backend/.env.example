# ==============================================================================
# OwlApi 环境变量配置模板
# ==============================================================================
# 使用方法:
#   make dev-init   → 复制到 backend/.env (开发环境)
#   make prod-init  → 复制到 deploy/.env  (生产环境)
# ==============================================================================

# ------------------------------------------------------------------------------
# 数据库配置
# ------------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=owlapi
DATABASE_URL=postgres://postgres:postgres@postgres:5432/owlapi?sslmode=disable

# ------------------------------------------------------------------------------
# 后端服务配置
# ------------------------------------------------------------------------------
OWLAPI_HTTP_PORT=:3000
OWLAPI_GRPC_PORT=:9090
OWLAPI_LOG_LEVEL=info
OWLAPI_JWT_SECRET=owlapi-dev-secret-change-me

# ------------------------------------------------------------------------------
# Gateway 配置
# ------------------------------------------------------------------------------
OWLAPI_SERVER_URL=dns:///backend:9090
OWLAPI_GATEWAY_ID=1
OWLAPI_GATEWAY_TOKEN=gw_29a08942fd727da982fc56b3c750b643
OWLAPI_TENANT_ID=1

# ------------------------------------------------------------------------------
# 前端配置
# ------------------------------------------------------------------------------
PUBLIC_API_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# 时区
# ------------------------------------------------------------------------------
TZ=Asia/Shanghai
