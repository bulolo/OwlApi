# ==============================================================================
# OwlApi 环境变量配置模板
# ==============================================================================
# 使用说明:
#   生产环境: make prod-init  → 复制到 deploy/.env，按需修改
#   开发环境: make dev-init   → 复制到 backend/.env，自动替换为本地地址
# ==============================================================================

# ------------------------------------------------------------------------------
# 数据库配置
# ------------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres         # 🔒 生产环境务必修改！
POSTGRES_DB=owlapi
DATABASE_URL=postgres://postgres:postgres@postgres:5432/owlapi?sslmode=disable

# ------------------------------------------------------------------------------
# 后端服务配置
# ------------------------------------------------------------------------------
OWLAPI_HTTP_PORT=:3000
OWLAPI_GRPC_PORT=:9090
OWLAPI_LOG_LEVEL=info
OWLAPI_JWT_SECRET=change-me-in-production  # 🔒 生产环境务必修改！建议: openssl rand -hex 32
# 开发环境改为: http://localhost:8001
OWLAPI_CORS_ORIGIN=https://admin.owlapi.cn

# ------------------------------------------------------------------------------
# Gateway 配置
# ------------------------------------------------------------------------------
OWLAPI_SERVER_URL=dns:///backend:9090
OWLAPI_GATEWAY_ID=1
OWLAPI_GATEWAY_TOKEN=gw_change-me-in-production  # 🔒 生产环境务必修改！建议: openssl rand -hex 16
OWLAPI_TENANT_ID=1

# ------------------------------------------------------------------------------
# 前端配置
# ------------------------------------------------------------------------------
# 开发环境改为: http://localhost:3000
PUBLIC_API_URL=https://api.owlapi.cn

# ------------------------------------------------------------------------------
# 时区
# ------------------------------------------------------------------------------
TZ=Asia/Shanghai
