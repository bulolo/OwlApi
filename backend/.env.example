# ==============================================================================
# OwlApi 环境变量配置模板
# ==============================================================================
# 使用方法: 复制此文件为 .env 并填入实际值
#   cp .env.example .env
# ==============================================================================

# ------------------------------------------------------------------------------
# 数据库配置
# ------------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<your-db-password>
POSTGRES_DB=owlapi
DATABASE_URL=postgres://postgres:<your-db-password>@postgres:5432/owlapi?sslmode=disable

# ------------------------------------------------------------------------------
# 后端服务配置
# ------------------------------------------------------------------------------
OWLAPI_HTTP_PORT=:3000
OWLAPI_GRPC_PORT=:9090
OWLAPI_LOG_LEVEL=info
OWLAPI_JWT_SECRET=<generate-a-random-secret-at-least-32-chars>
OWLAPI_CORS_ORIGIN=http://localhost:8001

# ------------------------------------------------------------------------------
# Gateway 配置
# ------------------------------------------------------------------------------
OWLAPI_SERVER_URL=dns:///backend:9090
OWLAPI_GATEWAY_ID=1
OWLAPI_GATEWAY_TOKEN=<generate-with-openssl-rand-hex-16>
OWLAPI_TENANT_ID=1

# ------------------------------------------------------------------------------
# 前端配置
# ------------------------------------------------------------------------------
PUBLIC_API_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# 时区
# ------------------------------------------------------------------------------
TZ=Asia/Shanghai
