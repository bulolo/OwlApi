FROM golang:1.24-alpine

WORKDIR /app

# Install basic tools
RUN apk add --no-cache git make curl

# Install Air via binary script to avoid go version dependency issues
# (air-verse/air is the new home for cosmtrek/air)
RUN curl -sSfL https://raw.githubusercontent.com/air-verse/air/master/install.sh | sh -s -- -b $(go env GOPATH)/bin

# Pre-copy go.mod to cache downloads
COPY go.mod go.sum ./
RUN go mod download

CMD ["air"]
