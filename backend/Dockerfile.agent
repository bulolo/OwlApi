# Build stage
FROM golang:1.22-alpine AS builder

WORKDIR /app

# Copy go mod files
COPY go.mod go.sum* ./
RUN go mod download

# Copy source code
COPY . .

# Build the agent binary
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-w -s" -o /agent ./cmd/agent

# Runtime stage
FROM alpine:3.19

RUN apk --no-cache add ca-certificates tzdata

WORKDIR /owlapi

# Create logs directory
RUN mkdir -p /owlapi/logs

COPY --from=builder /agent .

# Environment variables (defaults)
ENV OWLAPI_SERVER_URL=http://localhost:9090
ENV OWLAPI_AGENT_ID=""
ENV OWLAPI_AGENT_TOKEN=""
ENV OWLAPI_LOG_LEVEL=info
ENV OWLAPI_LOG_CONSOLE=false

CMD ["./agent"]
